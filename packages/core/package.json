{
  "name": "@soltaoverbo/core",
  "version": "0.3.0",
  "description": "Core logic for verbo.dev — parser, injector and spaced repetition",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.1"
  }
}
